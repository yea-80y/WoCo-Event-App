# ─────────────────────────────────────────────────────────────────────────────
# WoCo Events Server — environment configuration
# Copy this file to .env and fill in the values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── Swarm / Bee ──────────────────────────────────────────────────────────────

# URL of your Bee node's API. Point this at whichever Bee node you operate.
# Examples: http://localhost:1633  |  http://bee.internal:1633
BEE_URL=http://localhost:1633

# 64-character hex string identifying the postage batch to stamp uploads with.
# Buy a batch via your Bee node: POST /stamps/<amount>/<depth>
# See: https://docs.ethswarm.org/docs/develop/access-the-swarm/buy-a-stamp-batch
POSTAGE_BATCH_ID=

# ── Feed identity ────────────────────────────────────────────────────────────

# 32-byte (64 hex char) secp256k1 private key.
# This key owns ALL event and ticket feeds — keep it secret, back it up.
# Generate with:  openssl rand -hex 32
FEED_PRIVATE_KEY=

# ── Security ─────────────────────────────────────────────────────────────────

# Comma-separated list of frontend hostnames the server will accept session
# delegations from. Must exactly match what the browser sends as the page host.
# Example: devcon8.woco.eth,events.devcon.org,localhost:5173
ALLOWED_HOSTS=

# HMAC key for hashing claimer emails before they land on publicly-readable
# Swarm feeds. Without this, hashes are unsalted SHA-256 and trivially
# reversible via rainbow tables. The server REFUSES TO START if unset.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_HASH_SECRET=

# HMAC key for signing payment quotes (prevents client/server price slippage).
# Required for any event with crypto payments. Without it, /api/payment/quote
# cannot sign and all crypto payment claims will fail.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_QUOTE_SECRET=

# ── Stripe (optional — only needed if you enable card payments) ───────────────

# Your Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# Signing secret for connect-account webhook events (checkout.session.completed).
# Create a webhook endpoint in your Stripe dashboard → Webhooks → Add endpoint.
# URL: https://your-server/api/stripe/webhook  Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# Signing secret for platform-level webhook events (account.updated).
# Create a separate webhook endpoint for platform events.
STRIPE_WEBHOOK_SECRET_PLATFORM=

# ── Server ───────────────────────────────────────────────────────────────────

# Port the HTTP server listens on. Default: 3001
PORT=3001

# ── Etherna gateway (optional) ───────────────────────────────────────────────
# Set ETHERNA_ENABLED=true to route all Swarm traffic through gateway.etherna.io
# instead of a local Bee node. When enabled, BEE_URL is ignored and the four
# variables below are required (except ETHERNA_GATEWAY_URL / ETHERNA_TOKEN_ENDPOINT
# / ETHERNA_SCOPES which have sensible defaults).
#
# POSTAGE_BATCH_ID above must point to a batch provisioned via credit.etherna.io.
# FEED_PRIVATE_KEY remains the same — feeds are signed client-side by us, not
# by Etherna's identity.

ETHERNA_ENABLED=false

# API key from sso.etherna.io/Identity/Account/Manage/ApiKeys (format: <id>.<secret>)
ETHERNA_API_KEY=

# Optional overrides (defaults shown — set by Etherna for all integrators):
# ETHERNA_CLIENT_ID=apiKeyClientId
# ETHERNA_GATEWAY_URL=https://gateway.etherna.io
# ETHERNA_TOKEN_ENDPOINT=https://sso.etherna.io/connect/token
# ETHERNA_SCOPES=openid profile offline_access ether_accounts role userApi.gateway

# ── Etherna per-user batch provisioning ──────────────────────────────────────
# When a creator publishes a website via the Etherna gateway and has no batch,
# the server provisions one on-demand from Etherna's /stamps endpoint and bills
# the platform account. Per-event deploys never trigger provisioning — they
# fall back to ETHERNA_PLATFORM_BATCH.

# Set to "false" to disable per-user provisioning entirely (websites then 402).
BATCH_PER_USER_AUTO_PROVISION=true

# Shared batch used as fallback for EVENT deploys when the creator has no batch.
# Provision once via credit.etherna.io and paste the 64-hex batch ID here.
ETHERNA_PLATFORM_BATCH=

# Defaults for newly-provisioned user batches.
# Depth 19 → ~1.4 GiB usable.
# TTL is in days and MAY be fractional. 1.1 = 26h 24min — gives ~2.4h headroom
# above a 24h test so a slightly-stale Gnosis block timestamp can't expire the
# batch mid-deploy. Raise to 30 for production.
ETHERNA_USER_BATCH_DEPTH=19
ETHERNA_USER_BATCH_TTL_DAYS=1.1

# Safety margin added on top of the live chainstate price before purchase (percent).
ETHERNA_USER_BATCH_MARGIN_PCT=25

# Hard cap on per-purchase BZZ committed (1 BZZ = 1e16 PLUR). Refuses to call
# /stamps if amountPerChunk × 2^depth exceeds this. Actual xDai debit is
# usually a fraction of BZZ committed (BZZ trades below xDai), so this is a
# strict upper bound. 0.5 BZZ at depth 19 covers ~1.1 days comfortably.
ETHERNA_PURCHASE_MAX_BZZ=0.5

# ---------------------------------------------------------------------------
# Agent commerce surface (/api/agent/*) — demo + MCP tooling (scripts/agent/*)
# ---------------------------------------------------------------------------
# The runtime /api/agent/* endpoints need NO new secret (the agent holds its own
# key; the server only verifies the on-chain draw). These vars configure the
# OUT-OF-SERVER agent tooling: the E2E demo and the MCP server.
#
# Shared:
#   ZERODEV_RPC is reused for the agent's gasless USDC draw (already set for POS).
#
# Demo (apps/server/scripts/agent/demo.ts):
# AGENT_API_BASE=http://localhost:3001
# AGENT_DEMO_USER_PK=0x...        # test user key; its Kernel must hold Arb-Sepolia test USDC
# AGENT_DEMO_EVENT_ID=...         # event with a USDC/direct-transfer series on 421614
# AGENT_DEMO_SERIES_ID=...
# AGENT_DEMO_AGENT_PK=0x...       # optional; a fresh agent key is generated if unset
#
# MCP server (apps/server/scripts/agent/mcp.ts) — the agent's identity + granted budget:
# WOCO_AGENT_PK=0x...             # the agent's OWN key (the granted spender)
# WOCO_AGENT_APPROVAL=...         # serialized spend-permission approval the user granted
# WOCO_AGENT_USER_KERNEL=0x...    # user Kernel: funds source + ticket recipient
