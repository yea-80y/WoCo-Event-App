{
  "name": "woco",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @woco/web",
    "dev:server": "npm run dev -w @woco/server",
    "test:shared": "npm test -w @woco/shared",
    "build:web": "npm run build -w @woco/web",
    "build:server": "npm run build -w @woco/server",
    "build:embed": "npm run build -w @woco/embed",
    "build:deploy": "npm run build:web",
    "build:site": "npm run build:site -w @woco/web",
    "build:multisite": "npm run build:multisite -w @woco/web",
    "build:registry": "npm run build -w @woco/registry",
    "dev:registry": "npm run dev -w @woco/registry",
    "upload:swarm": "node scripts/upload-to-swarm-feed.cjs",
    "upload:site": "node scripts/upload-site-to-swarm.cjs",
    "deploy": "npm run build:deploy && npm run upload:swarm",
    "check": "npm run check --workspaces --if-present",
    "build:scanner": "npm run build:scanner -w @woco/web",
    "upload:scanner": "node scripts/upload-scanner-to-swarm.cjs",
    "deploy:scanner": "npm run build:scanner && npm run upload:scanner"
  },
  "devDependencies": {
    "@ethersphere/bee-js": "^11.1.0",
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "tar": "^7.5.9",
    "typescript": "~5.9.3"
  }
}
